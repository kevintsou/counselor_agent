# 軍師系統環境變數範本
# 複製成 .env 後填入實際 key：
#   cp .env.template .env
#   chmod 600 .env

# ===== 永豐 Shioaji（報價源）=====
SHIOAJI_API_KEY=your_shioaji_api_key_here
SHIOAJI_SECRET_KEY=your_shioaji_secret_key_here
SHIOAJI_PERSON_ID=your_person_id_here            # 通常是你的身份證字號
SHIOAJI_SIMULATED=1                              # 1=模擬帳戶 / 0=真實帳戶

# ===== MiniMax (LLM 軍師總司令) =====
MINIMAX_API_KEY=your_MiniMax_api_key_here
MINIMAX_MODEL=MiniMax-M2.7                # 官方模型名稱(不要加 minimax/ 前綴)
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ===== Telegram Bot（通訊兵 Herald）=====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=8432968775                      # Kevin 的 Telegram ID

# ===== RAG 書庫（軍師呼叫時自動檢索）=====
